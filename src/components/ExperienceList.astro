---
import { site } from '@/site.config';
---

<section class="container-wide py-12 sm:py-16">
  <h2
    class="text-sm font-mono uppercase tracking-wider text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]"
  >
    Experience
  </h2>
  <ol
    class="mt-6 space-y-10 border-l border-[var(--color-subtle)] pl-6 dark:border-[var(--color-subtle-dark)]"
  >
    {
      site.experience.map((org) => (
        <li class="relative">
          <span class="absolute -left-[29px] mt-1.5 inline-block h-2 w-2 rounded-full bg-[var(--color-accent)] dark:bg-[var(--color-accent-dark)]" />
          <div class="flex flex-col gap-1 sm:flex-row sm:items-baseline sm:justify-between">
            <h3 class="text-base font-semibold text-[var(--color-accent)] dark:text-[var(--color-accent-dark)]">
              {
                org.url ? (
                  <a class="link-quiet" href={org.url} target="_blank" rel="noopener noreferrer">
                    {org.org}
                  </a>
                ) : (
                  org.org
                )
              }
            </h3>
            <span class="font-mono text-xs text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
              {org.period}
            </span>
          </div>
          {org.roles.length === 1 ? (
            <div class="mt-2">
              <p class="text-sm font-medium">{org.roles[0]!.title}</p>
              <p
                class="mt-1 text-sm text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]"
                set:html={org.roles[0]!.summary}
              />
            </div>
          ) : (
            <ul class="mt-3 space-y-4 border-l border-[var(--color-subtle)] pl-5 dark:border-[var(--color-subtle-dark)]">
              {org.roles.map((role) => (
                <li class="relative">
                  <span class="absolute -left-[23px] top-2 inline-block h-1.5 w-1.5 rounded-full bg-[var(--color-muted)] dark:bg-[var(--color-muted-dark)]" />
                  <div class="flex flex-col gap-0.5 sm:flex-row sm:items-baseline sm:justify-between">
                    <p class="text-sm font-medium">{role.title}</p>
                    <span class="font-mono text-[11px] text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
                      {role.period}
                    </span>
                  </div>
                  <p
                    class="mt-1 text-sm text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]"
                    set:html={role.summary}
                  />
                </li>
              ))}
            </ul>
          )}
        </li>
      ))
    }
  </ol>
</section>
