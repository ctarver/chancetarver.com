---
import { Icon } from 'astro-icon/components';
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle dark mode"
  class="inline-flex h-9 w-9 items-center justify-center rounded-md text-[var(--color-muted)] transition-colors hover:bg-[var(--color-subtle)] hover:text-[var(--color-fg)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--color-accent)] dark:text-[var(--color-muted-dark)] dark:hover:bg-[var(--color-subtle-dark)] dark:hover:text-[var(--color-fg-dark)]"
>
  <Icon name="lucide:sun" class="hidden h-4 w-4 dark:block" />
  <Icon name="lucide:moon" class="block h-4 w-4 dark:hidden" />
</button>

<script is:inline>
  (function () {
    const KEY = 'theme';
    function setTheme(t) {
      document.documentElement.classList.toggle('dark', t === 'dark');
    }
    const btn = document.getElementById('theme-toggle');
    btn?.addEventListener('click', () => {
      const current = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
      const next = current === 'dark' ? 'light' : 'dark';
      localStorage.setItem(KEY, next);
      setTheme(next);
    });
  })();
</script>
