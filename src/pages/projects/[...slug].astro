---
import { getCollection, render } from 'astro:content';
import { Icon } from 'astro-icon/components';
import Base from '@/layouts/Base.astro';

export async function getStaticPaths() {
  const entries = await getCollection('projects');
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);
---

<Base title={data.title} description={data.summary} article={true}>
  <article class="container-prose py-12 sm:py-16">
    <a href="/projects/" class="link inline-flex items-center gap-1 text-sm">
      <Icon name="lucide:arrow-left" class="h-3.5 w-3.5" /> Projects
    </a>
    <header class="mt-6">
      <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
        {data.period}{data.role ? ` · ${data.role}` : ''}
      </p>
      <h1 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">{data.title}</h1>
      <p class="mt-3 text-lg text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
        {data.summary}
      </p>
    </header>

    {
      data.tech.length > 0 && (
        <ul class="mt-6 flex flex-wrap gap-1.5">
          {data.tech.map((t) => (
            <li class="rounded-sm border border-[var(--color-subtle)] px-1.5 py-0.5 font-mono text-[10px] uppercase tracking-wider text-[var(--color-muted)] dark:border-[var(--color-subtle-dark)] dark:text-[var(--color-muted-dark)]">
              {t}
            </li>
          ))}
        </ul>
      )
    }

    <section class="mt-8 prose-custom">
      <Content />
    </section>

    {
      data.links.length > 0 && (
        <section class="mt-10 border-t border-[var(--color-subtle)] pt-6 dark:border-[var(--color-subtle-dark)]">
          <h2 class="font-mono text-xs uppercase tracking-wider text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
            Links
          </h2>
          <ul class="mt-3 space-y-1">
            {data.links.map((l) => (
              <li>
                <a href={l.url} target="_blank" rel="noopener noreferrer" class="link inline-flex items-center gap-1.5 text-sm">
                  <Icon name="lucide:external-link" class="h-3.5 w-3.5" /> {l.label}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</Base>
