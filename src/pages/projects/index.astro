---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import ProjectCard from '@/components/ProjectCard.astro';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
---

<Base
  title="Projects"
  description="Selected research and engineering work in wireless, DSP, and ML for the radio."
>
  <section class="container-wide pt-12 pb-16 sm:pt-16">
    <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Projects</h1>
    <p class="mt-3 max-w-2xl text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
      A hand-curated slice of work. What I'm actively investing in and what I'd want a
      colleague at a new lab to know about.
    </p>
    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((p) => <ProjectCard entry={p} />)}
    </div>
  </section>
</Base>
