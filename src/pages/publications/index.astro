---
import { getCollection } from 'astro:content';
import Base from '@/layouts/Base.astro';
import PublicationItem from '@/components/PublicationItem.astro';
import { PUBLICATION_TYPE_LABEL } from '@/lib/format';

const all = await getCollection('publications');
const sorted = all.sort((a, b) => {
  const da = a.data.date?.getTime() ?? new Date(a.data.year, 0).getTime();
  const db = b.data.date?.getTime() ?? new Date(b.data.year, 0).getTime();
  return db - da;
});

const byYear = new Map<number, typeof sorted>();
for (const p of sorted) {
  const arr = byYear.get(p.data.year) ?? [];
  arr.push(p);
  byYear.set(p.data.year, arr);
}
const years = [...byYear.keys()].sort((a, b) => b - a);

const typeCounts = new Map<string, number>();
for (const p of sorted) {
  typeCounts.set(p.data.type, (typeCounts.get(p.data.type) ?? 0) + 1);
}
const types = [...typeCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<Base
  title="Publications"
  description="Peer-reviewed papers, journal articles, patents, and the thesis."
>
  <section class="container-wide pt-12 pb-8 sm:pt-16">
    <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">Publications</h1>
    <p class="mt-3 max-w-2xl text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
      {sorted.length} entries across journals, conferences, patents, and a thesis. Filter by
      type or jump to a year.
    </p>

    <div class="mt-6 flex flex-wrap gap-2">
      <button
        type="button"
        data-filter="all"
        class="filter-btn active rounded-full border border-[var(--color-accent)] bg-[var(--color-accent)] px-3 py-1 font-mono text-xs uppercase tracking-wider text-white transition-colors dark:border-[var(--color-accent-dark)] dark:bg-[var(--color-accent-dark)] dark:text-[var(--color-bg-dark)]"
      >
        All ({sorted.length})
      </button>
      {
        types.map(([t, n]) => (
          <button
            type="button"
            data-filter={t}
            class="filter-btn rounded-full border border-[var(--color-subtle)] px-3 py-1 font-mono text-xs uppercase tracking-wider text-[var(--color-muted)] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] dark:border-[var(--color-subtle-dark)] dark:text-[var(--color-muted-dark)] dark:hover:border-[var(--color-accent-dark)] dark:hover:text-[var(--color-accent-dark)]"
          >
            {PUBLICATION_TYPE_LABEL[t] ?? t} ({n})
          </button>
        ))
      }
    </div>
  </section>

  <section class="container-wide pb-16">
    {
      years.map((year) => (
        <div class="year-group" data-year={year}>
          <h2 class="sticky top-14 z-10 -mx-6 mb-2 border-y border-[var(--color-subtle)] bg-[color-mix(in_srgb,var(--color-bg)_92%,transparent)] px-6 py-2 font-mono text-sm uppercase tracking-wider text-[var(--color-muted)] backdrop-blur dark:border-[var(--color-subtle-dark)] dark:bg-[color-mix(in_srgb,var(--color-bg-dark)_92%,transparent)] dark:text-[var(--color-muted-dark)]">
            {year}
          </h2>
          <div class="divide-y divide-[var(--color-subtle)] dark:divide-[var(--color-subtle-dark)]">
            {byYear.get(year)!.map((p) => (
              <div data-type={p.data.type} class="pub-row">
                <PublicationItem entry={p} />
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </section>
</Base>

<script is:inline>
  (function () {
    const buttons = document.querySelectorAll('.filter-btn');
    const rows = document.querySelectorAll('.pub-row');
    const groups = document.querySelectorAll('.year-group');
    const activeClasses = [
      'border-[var(--color-accent)]',
      'bg-[var(--color-accent)]',
      'text-white',
      'dark:border-[var(--color-accent-dark)]',
      'dark:bg-[var(--color-accent-dark)]',
      'dark:text-[var(--color-bg-dark)]',
    ];
    buttons.forEach((b) => {
      b.addEventListener('click', () => {
        buttons.forEach((x) => {
          x.classList.remove(...activeClasses);
        });
        b.classList.add(...activeClasses);
        const f = b.getAttribute('data-filter');
        rows.forEach((r) => {
          const t = r.getAttribute('data-type');
          r.style.display = f === 'all' || t === f ? '' : 'none';
        });
        groups.forEach((g) => {
          const visible = g.querySelectorAll('.pub-row:not([style*="display: none"])').length;
          g.style.display = visible === 0 ? 'none' : '';
        });
      });
    });
  })();
</script>
