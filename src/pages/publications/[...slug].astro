---
import { getCollection, render } from 'astro:content';
import { Icon } from 'astro-icon/components';
import Base from '@/layouts/Base.astro';
import { formatAuthors, PUBLICATION_TYPE_LABEL, extractYouTubeId } from '@/lib/format';

export async function getStaticPaths() {
  const entries = await getCollection('publications');
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);
const authorsHtml = formatAuthors(data.authors);
const doiUrl = data.doi
  ? data.doi.startsWith('http')
    ? data.doi
    : `https://doi.org/${data.doi}`
  : undefined;
const youtubeId = extractYouTubeId(data.youtube);
---

<Base
  title={data.title}
  description={data.abstract ?? `${data.title}. ${data.venue} (${data.year}).`}
  article={true}
>
  <article class="container-prose py-12 sm:py-16">
    <a href="/publications" class="link inline-flex items-center gap-1 text-sm">
      <Icon name="lucide:arrow-left" class="h-3.5 w-3.5" /> Publications
    </a>

    <span
      class="mt-6 inline-block rounded-sm border border-[var(--color-subtle)] px-1.5 py-0.5 font-mono text-[10px] tracking-wider uppercase text-[var(--color-muted)] dark:border-[var(--color-subtle-dark)] dark:text-[var(--color-muted-dark)]"
    >
      {PUBLICATION_TYPE_LABEL[data.type] ?? data.type}
    </span>
    <h1 class="mt-2 text-2xl font-semibold leading-tight tracking-tight sm:text-3xl">
      {data.title}
    </h1>
    <p class="mt-3 text-sm text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]" set:html={authorsHtml} />
    <p class="mt-1 text-sm italic text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
      {data.venue} · {data.year}
    </p>

    <div class="mt-6 flex flex-wrap gap-2">
      {data.pdf && (
        <a href={data.pdf} target="_blank" rel="noopener noreferrer" class="link inline-flex items-center gap-1 text-sm">
          <Icon name="lucide:file-text" class="h-3.5 w-3.5" /> PDF
        </a>
      )}
      {doiUrl && (
        <a href={doiUrl} target="_blank" rel="noopener noreferrer" class="link inline-flex items-center gap-1 text-sm">
          <Icon name="lucide:link" class="h-3.5 w-3.5" /> DOI
        </a>
      )}
      {data.arxiv && (
        <a href={data.arxiv} target="_blank" rel="noopener noreferrer" class="link inline-flex items-center gap-1 text-sm">
          <Icon name="simple-icons:arxiv" class="h-3.5 w-3.5" /> arXiv
        </a>
      )}
      {data.code && (
        <a href={data.code} target="_blank" rel="noopener noreferrer" class="link inline-flex items-center gap-1 text-sm">
          <Icon name="simple-icons:github" class="h-3.5 w-3.5" /> Code
        </a>
      )}
      {data.url && (
        <a href={data.url} target="_blank" rel="noopener noreferrer" class="link inline-flex items-center gap-1 text-sm">
          <Icon name="lucide:external-link" class="h-3.5 w-3.5" /> Link
        </a>
      )}
      {data.youtube && (
        <a href={data.youtube} target="_blank" rel="noopener noreferrer" class="link inline-flex items-center gap-1 text-sm">
          <Icon name="lucide:youtube" class="h-3.5 w-3.5" /> YouTube
        </a>
      )}
    </div>

    {
      youtubeId && (
        <div class="mt-8 aspect-video overflow-hidden rounded-lg border border-[var(--color-subtle)] dark:border-[var(--color-subtle-dark)]">
          <iframe
            src={`https://www.youtube-nocookie.com/embed/${youtubeId}`}
            title={data.title}
            loading="lazy"
            allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            class="h-full w-full"
          />
        </div>
      )
    }

    {
      data.abstract && (
        <section class="mt-8 prose-custom">
          <h2>Abstract</h2>
          <p>{data.abstract}</p>
        </section>
      )
    }

    <section class="mt-8 prose-custom">
      <Content />
    </section>

    {
      data.bibtex && (
        <details class="mt-10 rounded-md border border-[var(--color-subtle)] p-4 dark:border-[var(--color-subtle-dark)]">
          <summary class="cursor-pointer font-mono text-xs uppercase tracking-wider text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
            BibTeX
          </summary>
          <pre class="mt-3 overflow-x-auto text-xs">{data.bibtex}</pre>
        </details>
      )
    }

    {
      data.tags.length > 0 && (
        <ul class="mt-8 flex flex-wrap gap-2">
          {data.tags.map((t) => (
            <li class="rounded-sm border border-[var(--color-subtle)] px-1.5 py-0.5 font-mono text-[10px] uppercase tracking-wider text-[var(--color-muted)] dark:border-[var(--color-subtle-dark)] dark:text-[var(--color-muted-dark)]">
              #{t}
            </li>
          ))}
        </ul>
      )
    }
  </article>
</Base>
