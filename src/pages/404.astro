---
import Base from '@/layouts/Base.astro';
---

<Base title="Not Found" description="Page not found.">
  <section class="container-prose flex min-h-[50vh] flex-col items-center justify-center py-20 text-center">
    <p class="font-mono text-xs uppercase tracking-wider text-[var(--color-accent)] dark:text-[var(--color-accent-dark)]">
      404
    </p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight">Page not found</h1>
    <p class="mt-4 max-w-md text-[var(--color-muted)] dark:text-[var(--color-muted-dark)]">
      The page you were looking for doesn't exist. It may have moved during the site rebuild.
      Try the <a href="/" class="link">home page</a> or
      <a href="/publications" class="link">publications</a>.
    </p>
  </section>
</Base>
